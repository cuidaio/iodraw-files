{"root":{"data":{"id":"dhwt4pnymqg0","created":1776568943556,"text":"助人行为"},"children":[{"data":{"id":"dhwuege7n3k0","created":1776572528127,"text":" 社会行为的起源"},"children":[{"data":{"id":"dhwynlgx7qg0","created":1776584528892,"text":"基因的遗传造成了行为的先天性"},"children":[{"data":{"id":"dhwynp9tsrc0","created":1776584537170,"text":"社会生物学视角"},"children":[]}]},{"data":{"id":"dhwynxh4yq80","created":1776584555026,"text":"人与人之间的相互作用\n以最大化利益/最小化代价为目的"},"children":[{"data":{"id":"dhwyok29ck00","created":1776584604193,"text":"社会交换理论"},"children":[]}]},{"data":{"id":"dhwyov8dobk0","created":1776584628507,"text":"社会规范的随处可见本身\n构成了学习规范的文化基础"},"children":[{"data":{"id":"dhwypph61xc0","created":1776584694342,"text":"社会规范论"},"children":[]}]},{"data":{"id":"dhwyqiznsb40","created":1776584758587,"text":"某种行动能够带来收益\n产生这种行为的心理机制就能得到强化"},"children":[{"data":{"id":"dhwyqwf6f1s0","created":1776584787823,"text":"进化心理学视角"},"children":[]}]}]},{"data":{"id":"dhwytfrag5k0","created":1776584986643,"text":"几种观察，假设与实验"},"children":[{"data":{"id":"dhwytntcb0w0","created":1776585004181,"text":"在场的旁观者越多，\n帮助的可能性越低"},"children":[{"data":{"id":"dhwyuj2ecmg0","created":1776585072209,"text":"named as 旁观者效应"},"children":[]},{"data":{"id":"dhwyuufilcg0","created":1776585096947,"text":"by 拉特纳和达利"},"children":[]},{"data":{"id":"dhwzkwuerko0","created":1776587139669,"text":"解释"},"children":[{"data":{"id":"dhwzkye9zcw0","created":1776587143047,"text":"人数↑→↓单人责任感"},"children":[]},{"data":{"id":"dhwzl5jo6pk0","created":1776587158611,"text":"情境不确定"},"children":[]}]},{"data":{"id":"dhwzlgx9z6o0","created":1776587183378,"text":"实验"},"children":[{"data":{"id":"dhwzljcwr2g0","created":1776587188677,"text":"别人的在场会影响助人行为吗？"},"children":[]},{"data":{"id":"dhwzm4c776g0","created":1776587234347,"text":"三幻神"},"children":[{"data":{"id":"dhwzmfredso0","created":1776587259210,"text":"紧急报警"},"children":[]},{"data":{"id":"dhwzmhmvpo80","created":1776587263291,"text":"紧急救人"},"children":[]},{"data":{"id":"dhwzmjqk9800","created":1776587267867,"text":"不幸女士"},"children":[]}]}]}]},{"data":{"id":"dhwzr0mhwe80","created":1776587618083,"text":"引入力场模型来解释"},"children":[{"data":{"id":"dhwzruuga880","created":1776587683867,"text":"社会作用力理论"},"children":[{"data":{"id":"dhwzryxpln40","created":1776587692772,"text":"obj：存在/行动，真实的隐含的想象的\n对\nsbj：个体的心理状态/主观情感、动机和情绪、认知和信念、价值和行为等\n的影响/引发的任何一种变化"},"children":[]},{"data":{"id":"dhwzu6ogf2w0","created":1776587866355,"text":"分支主题"},"children":[]}]}]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}