14o0","created":1777644733921,"text":"+ 物质支持 → + 良好环境刺激 → 满足需求"},"children":[]},{"data":{"id":"di7ehem1bwg0","created":1777644781104,"text":"++ 确立自身优势，正确的应对技能"},"children":[]},{"data":{"id":"di7ehwapnc00","created":1777644819601,"text":"奖励积极社会行为 → 心理社会发展"},"children":[]}]}]},{"data":{"id":"di7eibsrx000","created":1777644853345,"text":"情绪发展"},"children":[{"data":{"id":"di7eicz3jew0","created":1777644855904,"text":"体验和调节情绪的健康性 ~ 自尊，构建人际关系能力"},"children":[]},{"data":{"id":"di7ekwyz5q00","created":1777645056161,"text":"能理解基本的情绪，但很难意识到情绪本身"},"children":[]},{"data":{"id":"di7ekm2kciw0","created":1777645032433,"text":"识别他人情绪中的非言语内容 > 共情能力，构建健康人际关系能力"},"children":[]},{"data":{"id":"di7emgd3mzs0","created":1777645176738,"text":"观察与互动学习"},"children":[{"data":{"id":"di7emml7cn40","created":1777645190288,"text":"不恰当反应模式 → + 无益的情绪反应模式"},"children":[]}]},{"data":{"id":"di7elvw9v1c0","created":1777645132185,"text":"+ 先天发育障碍（孤独症） → ↓情绪识别和调节能力"},"children":[]}]},{"data":{"id":"di7eonxvyls0","created":1777645349960,"text":"常见问题"},"children":[{"data":{"id":"di7eopwn0h40","created":1777645354239,"text":"- 表达能力 → 行为表现挣扎 → + 行为问题"},"children":[]},{"data":{"id":"di7ep1rv6ps0","created":1777645380071,"text":"发脾气，肢体冲突…… > 行为问题"},"children":[]},{"data":{"id":"di7eq4njqso0","created":1777645464705,"text":"[?→行为问题]：重大生活事件，创伤经历"},"children":[]},{"data":{"id":"di7equ3iaq80","created":1777645520089,"text":"失去亲人，进入新的幼儿园 > 重大生活事件"},"children":[]},{"data":{"id":"di7er404vgg0","created":1777645541653,"text":"虐待，忽视 > 创伤事件"},"children":[]}]}]},{"data":{"id":"di7gg15syh40","created":1777650315680,"text":"儿童期"},"children":[{"data":{"id":"di7gg33cfjk0","created":1777650319885,"text":"生理发展"},"children":[{"data":{"id":"di7ghj8x2nc0","created":1777650433414,"text":"女孩发育快于男孩"},"children":[]},{"data":{"id":"di7ghtb2iso0","created":1777650455312,"text":"早熟现象很常见"},"children":[]},{"data":{"id":"di7ghxaumc00","created":1777650464006,"text":"小肌肉发展 → ↑精细动作"},"children":[]},{"data":{"id":"di7giahphf40","created":1777650492719,"text":" 十小时睡眠 ~ 睡眠充足 or ↓心理功能，身体发育"},"children":[]},{"data":{"id":"di7gj89cayw0","created":1777650566224,"text":"第二性征发育，↑身体间差异 → 对身体的不安全感"},"children":[]},{"data":{"id":"di7gk1j72200","created":1777650629946,"text":"[？→↓不安全感]：告知身体的不同的美"},"children":[]}]},{"data":{"id":"di7gl2ekj4g0","created":1777650710207,"text":"认知发展"},"children":[{"data":{"id":"di7gl3ahpbk0","created":1777650712138,"text":"具体运算阶段"},"children":[]},{"data":{"id":"di7gl6blfvk0","created":1777650718735,"text":"前额叶发育 → +新思维，互动方式"},"children":[]},{"data":{"id":"di7glrlt0io0","created":1777650765065,"text":"分支主题"},"children":[]}]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}