{"root":{"data":{"id":"dhopkondq3k0","created":1775746431078,"text":"社会知觉"},"children":[{"data":{"id":"dhopmtcr3g80","created":1775746598047,"text":"社会知觉的概念"},"children":[{"data":{"id":"dhopo7osw5c0","created":1775746707615,"text":"定义"},"children":[{"data":{"id":"dhopr5js61c0","created":1775746938050,"text":"指人对【社会性的】人和事物【形成】的整体性的印象，\n对【各种担负社会角色并具有个性色彩的】人，\n或是人与人之间的关系或对群体所建立的\n最初印象和概念。"},"children":[]}]},{"data":{"id":"dhopo9ojmag0","created":1775746711953,"text":"分类"},"children":[]},{"data":{"id":"dhopobbrgeo0","created":1775746715534,"text":"一些相关概念"},"children":[]}]},{"data":{"id":"dhopn61rttc0","created":1775746625681,"text":"知觉输入的结果：印象"},"children":[{"data":{"id":"dhoposcrt9c0","created":1775746752600,"text":"定义"},"children":[]},{"data":{"id":"dhopoujvmsg0","created":1775746757383,"text":"性质"},"children":[]},{"data":{"id":"dhopoyloadc0","created":1775746766199,"text":"形成模式"},"children":[]},{"data":{"id":"dhopp2a4sm80","created":1775746774208,"text":"信息选择倾向"},"children":[]}]},{"data":{"id":"dhopn8z6qew0","created":1775746632055,"text":"有目的的偏差：认知偏差"},"children":[]},{"data":{"id":"dhopnc60vnk0","created":1775746638999,"text":"从输入到输出：印象管理"},"children":[]},{"data":{"id":"dhopnfxs4ps0","created":1775746647208,"text":"认知的视角：内隐认知"},"children":[]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}