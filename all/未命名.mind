{"root":{"data":{"id":"dhopkondq3k0","created":1775746431078,"text":"社会知觉"},"children":[{"data":{"id":"dhopmtcr3g80","created":1775746598047,"text":"社会知觉的概念"},"children":[{"data":{"id":"dhopo7osw5c0","created":1775746707615,"text":"定义"},"children":[{"data":{"id":"dhopr5js61c0","created":1775746938050,"text":"指人对【社会性的】人和事物【形成】的整体性的印象，\n对【各种担负社会角色并具有个性色彩的】人，\n或是人与人之间的关系或对群体所建立的\n最初印象和概念。"},"children":[]}]},{"data":{"id":"dhopo9ojmag0","created":1775746711953,"text":"分类"},"children":[{"data":{"id":"dhopwtfs2jc0","created":1775747381872,"text":"3类知觉；自我知觉理论（贝姆）"},"children":[{"data":{"id":"dhopx1os9cw0","created":1775747399831,"text":"自我"},"children":[{"data":{"id":"dhopxty437k0","created":1775747461345,"text":"自我价值定向理论：人具有解释自我的基本需求"},"children":[]}]},{"data":{"id":"dhopx63k44o0","created":1775747409431,"text":"他人"},"children":[]},{"data":{"id":"dhopx7fqmug0","created":1775747412344,"text":"人际"},"children":[]}]}]},{"data":{"id":"dhopobbrgeo0","created":1775746715534,"text":"一些相关概念"},"children":[{"data":{"id":"dhopygym60o0","created":1775747511441,"text":"印象"},"children":[{"data":{"id":"dhopyl9rixs0","created":1775747520822,"text":"是社会知觉的结果；过程与结果的关系"},"children":[]}]},{"data":{"id":"dhopye6y5bk0","created":1775747505414,"text":"一般知觉"},"children":[{"data":{"id":"dhoq1h14yjs0","created":1775747746687,"text":"主要指对【物】的物理特性，时间，运动等的关注"},"children":[]}]},{"data":{"id":"dhopyg56zz40","created":1775747509662,"text":"社会认知"},"children":[{"data":{"id":"dhopyok2dg00","created":1775747527975,"text":"是…的上位概念；社会知觉是社会认知的一个环节"},"children":[]}]},{"data":{"id":"dhopyht5k1k0","created":1775747513288,"text":"社会推理(?)"},"children":[{"data":{"id":"dhoq4r5azps0","created":1775748003798,"text":"也是社会认知的一个环节，涉及到加工、解释、判断，结果是社会判断，和社会知觉同级。"},"children":[]}]}]}]},{"data":{"id":"dhopn61rttc0","created":1775746625681,"text":"知觉输入的结果：印象"},"children":[{"data":{"id":"dhoposcrt9c0","created":1775746752600,"text":"指人在遇到最初遇到的【新的社会情境】时，\n主观上按照自己以【已有经验】为基础的【理解】，\n将情境中的人或事物进行归类后所形成的对于人或事物的【概念】；\n是社会知觉过程的结果。"},"children":[]},{"data":{"id":"dhopoujvmsg0","created":1775746757383,"text":"性质"},"children":[{"data":{"id":"dhor3gj68ig0","created":1775750723438,"text":"间接性、固执性、综合性"},"children":[]}]},{"data":{"id":"dhopoyloadc0","created":1775746766199,"text":"形成模式"},"children":[{"data":{"id":"dhor6f5nxw80","created":1775750955537,"text":"加法模式"},"children":[]},{"data":{"id":"dhor6n7iyeo0","created":1775750973064,"text":"平均模式"},"children":[]},{"data":{"id":"dhor6plxhig0","created":1775750978288,"text":"加权平均模式"},"children":[]},{"data":{"id":"dhor6rwrpvk0","created":1775750983297,"text":"中心品质理论"},"children":[{"data":{"id":"dhorbvpux0o0","created":1775751383407,"text":"有些信息资料重要性显著大于其它，被称作和新特性；"},"children":[{"data":{"id":"dhorcgt6cog0","created":1775751429320,"text":"所罗门阿希的性格词实验"},"children":[]},{"data":{"id":"dhorcm8c5wg0","created":1775751441121,"text":"凯利的内隐人格理论"},"children":[]}]}]}]},{"data":{"id":"dhopp2a4sm80","created":1775746774208,"text":"信息选择倾向"},"children":[{"data":{"id":"dhordfgjln40","created":1775751504744,"text":"自然特征"},"children":[{"data":{"id":"dhordmo4dq80","created":1775751520439,"text":"性别种族外貌吸引力"},"children":[]}]},{"data":{"id":"dhordit7fm80","created":1775751512040,"text":"社会特征"},"children":[{"data":{"id":"dhore5xxgfc0","created":1775751562391,"text":"所属群体和社会角色"},"children":[]}]},{"data":{"id":"dhordkbdgeg0","created":1775751515315,"text":"心理特征"},"children":[{"data":{"id":"dhore9nz9aw0","created":1775751570497,"text":"人际关系特征、智力特征"},"children":[]}]}]},{"data":{"id":"dhorf2p0sow0","created":1775751633687,"text":"具体知觉的构成"},"children":[{"data":{"id":"dhorf84b9pk0","created":1775751645495,"text":"他人情绪"},"children":[{"data":{"id":"dhorfc2a66o0","created":1775751654079,"text":"表情线索"},"children":[{"data":{"id":"dhorfgyiqyw0","created":1775751664736,"text":"面部表情"},"children":[{"data":{"id":"dhoriv9ef8o0","created":1775751930961,"text":"面部情绪表达"},"children":[]}]},{"data":{"id":"dhorfiueo140","created":1775751668841,"text":"身段表情"},"children":[{"data":{"id":"dhorixtijhk0","created":1775751936531,"text":"姿态情绪表达"},"children":[]}]},{"data":{"id":"dhorfm4jsf40","created":1775751675984,"text":"言语表情"},"children":[{"data":{"id":"dhorfqf7bfs0","created":1775751685336,"text":"声调、音色和快慢"},"children":[]}]}]}]},{"data":{"id":"dhorfa146ts0","created":1775751649655,"text":"他人个性"},"children":[{"data":{"id":"dhorhj6k4r40","created":1775751826304,"text":"【社会关系模型】"},"children":[{"data":{"id":"dhorhlb5f8w0","created":1775751830935,"text":"【认知者】的评价标准（主体）"},"children":[]},{"data":{"id":"dhorhngp3og0","created":1775751835624,"text":"【行动者】"},"children":[]},{"data":{"id":"dhorhotejw00","created":1775751838569,"text":"认知者和行动者的【特殊关系】"},"children":[]}]}]}]}]},{"data":{"id":"dhopn8z6qew0","created":1775746632055,"text":"有目的的偏差：认知偏差"},"children":[{"data":{"id":"dhorjap2h0g0","created":1775751964560,"text":"首因效应"},"children":[]},{"data":{"id":"dhorjcwld3s0","created":1775751969369,"text":"近因效应"},"children":[]},{"data":{"id":"dhorje4msrk0","created":1775751972032,"text":"晕轮效应"},"children":[]},{"data":{"id":"dhorjfhsce00","created":1775751975004,"text":"预言的自我实现效应"},"children":[{"data":{"id":"dhorl27fzwo0","created":1775752102809,"text":"如何产生"},"children":[{"data":{"id":"dhormwrlodc0","created":1775752247695,"text":"知觉者：期望→行动→[被知觉者：解释→反应]→与期望一致"},"children":[]}]},{"data":{"id":"dhorm4973a00","created":1775752185632,"text":"如何纠正"},"children":[{"data":{"id":"dhorm617rh40","created":1775752189503,"text":"补偿知觉者对目标人物的期望"},"children":[]},{"data":{"id":"dhormedtvlk0","created":1775752207680,"text":"被知觉者积极消除知觉者的期望"},"children":[]}]},{"data":{"id":"dhornuxbm9c0","created":1775752322052,"text":"分支主题"},"children":[]}]},{"data":{"id":"dhorjiu44e80","created":1775751982280,"text":"证实偏差"},"children":[]},{"data":{"id":"dhorjpjw5oo0","created":1775751996899,"text":"后视偏差"},"children":[{"data":{"id":"dhorns09pds0","created":1775752315700,"text":"我早知道效应"},"children":[]}]},{"data":{"id":"dhorjryd5c80","created":1775752002128,"text":"认知启发"},"children":[{"data":{"id":"dhorjva02m00","created":1775752009362,"text":"代表性启发/表征性启发"},"children":[]},{"data":{"id":"dhorkcd3zvk0","created":1775752046555,"text":"可用性启发/易得性启发"},"children":[]},{"data":{"id":"dhorkh1a47k0","created":1775752056724,"text":"调整性启发"},"children":[]}]}]},{"data":{"id":"dhopnc60vnk0","created":1775746638999,"text":"从输入到输出：印象管理"},"children":[]},{"data":{"id":"dhopnfxs4ps0","created":1775746647208,"text":"认知的视角：内隐认知"},"children":[]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}