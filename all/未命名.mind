dhr36h8rbds0","created":1775987933310,"text":"两种人","expandState":"expand"},"children":[{"data":{"id":"dhr36j0dzzs0","created":1775987937157,"text":"概化他人"},"children":[]},{"data":{"id":"dhr36o3b6k80","created":1775987948218,"text":"重要他人"},"children":[]}]},{"data":{"id":"dhr39pkrj9k0","created":1775988186542,"text":"评价"},"children":[{"data":{"id":"dhr39sbz6880","created":1775988192541,"text":"理论上自圆其说"},"children":[]},{"data":{"id":"dhr39wppazk0","created":1775988202078,"text":"回应了？？的“镜像自我”的理论困惑（？）"},"children":[]}]}]},{"data":{"id":"dhr2wg41xxs0","created":1775987147207,"text":"精神分析的三人"},"children":[{"data":{"id":"dhr2wiyp7yw0","created":1775987153413,"text":"弗洛伊德"},"children":[{"data":{"id":"dhr3cijcy000","created":1775988406312,"text":"自我作为本我和超我的调节"},"children":[]},{"data":{"id":"dhr3cr86qs80","created":1775988425228,"text":"无法抑制本我和超我的冲突时，要么获得精神疾病，要么（人性）升华"},"children":[]}]},{"data":{"id":"dhr2wto4xy80","created":1775987176719,"text":"埃里克森"},"children":[{"data":{"id":"dhr3cchja6w0","created":1775988393141,"text":"自我同一性问题及其克服"},"children":[]}]},{"data":{"id":"dhr2wv7k5200","created":1775987180071,"text":"沙利文"},"children":[{"data":{"id":"dhr3c66dlpc0","created":1775988379406,"text":"母婴关系作为人际关系的基础"},"children":[]}]}]},{"data":{"id":"dhr2wwkmy7k0","created":1775987183038,"text":"罗杰斯"},"children":[{"data":{"id":"dhr3dmfwngo0","created":1775988493175,"text":"詹姆斯和米德的自我理论的集大成者"},"children":[]},{"data":{"id":"dhr36z924bc0","created":1775987972510,"text":"理想自我"},"children":[]}]},{"data":{"id":"dhr2zp54xw00","created":1775987401956,"text":"希金斯自我差距理论"},"children":[{"data":{"id":"dhr3fi0cucg0","created":1775988640256,"text":"三个自我","expandState":"expand"},"children":[{"data":{"id":"dhr3fnm0gvc0","created":1775988652449,"text":"自我导向/标准","expandState":"expand"},"children":[{"data":{"id":"dhr35witm740","created":1775987888206,"text":"应该自我"},"children":[]},{"data":{"id":"dhr35vhary00","created":1775987885937,"text":"理想自我"},"children":[]}]},{"data":{"id":"dhr35t1fbqg0","created":1775987880624,"text":"现实自我"},"children":[]}]},{"data":{"id":"dhr3fvtjb9k0","created":1775988670318,"text":"自我差距"},"children":[{"data":{"id":"dhr3fyqkxz40","created":1775988676670,"text":"现实自我和理想自我"},"children":[{"data":{"id":"dhr3g177th40","created":1775988682030,"text":"抑郁类情绪"},"children":[]}]},{"data":{"id":"dhr3g40fypk0","created":1775988688150,"text":"现实自我和应该自我"},"children":[{"data":{"id":"dhr3g7rzzpk0","created":1775988696347,"text":"焦虑类情绪"},"children":[]}]}]}]}]},{"data":{"id":"dhr3n8m4vig0","created":1775989246718,"text":"功能"},"children":[{"data":{"id":"dhr3na77x7k0","created":1775989250170,"text":"维持一致性"},"children":[{"data":{"id":"dhr3ohwdqfc0","created":1775989345293,"text":"自我概念使人保持内在一致性"},"children":[]},{"data":{"id":"dhr3pb79je80","created":1775989409078,"text":"金盛华的自我价值定向理论"},"children":[]}]},{"data":{"id":"dhr3ng8079s0","created":1775989263278,"text":"经验解释"},"children":[{"data":{"id":"dhr3ov0lue00","created":1775989373847,"text":"一定经验对个体具有特定意义，取决于经验解释的自我概念背景"},"children":[]},{"data":{"id":"dhr3p8evc7s0","created":1775989403007,"text":"梅德维克"},"children":[]}]},{"data":{"id":"dhr3niitnqw0","created":1775989268286,"text":"期望定向"},"children":[{"data":{"id":"dhr3nm2iraw0","created":1775989276007,"text":"伯恩斯"},"children":[]},{"data":{"id":"dhr3nnfg3w80","created":1775989278966,"text":"研究学生对自身的期望和学习动机、学习行为的关系"},"children":[]},{"data":{"id":"dhr3r39v6tk0","created":1775989548549,"text":"人们对情景和自身行为的期望是受自我概念引导的"},"children":[]}]}]}]},{"data":{"id":"dhr2ua2jtgw0","created":1775986977327,"text":"自我效能感"},"children":[{"data":{"id":"dhr2uzhyo880","created":1775987032678,"text":"定义"},"children":[{"data":{"id":"dhr2z5d5zw80","created":1775987358906,"text":"指一个人感到自己能够胜任或有效的感觉"},"children":[]}]},{"data":{"id":"dhr420pzdu00","created":1775990404999,"text":"两个因素"},"children":[{"data":{"id":"dhr421yjabc0","created":1775990407693,"text":"成功经验"},"children":[]},{"data":{"id":"dhr429ulniw0","created":1775990424869,"text":"个人控制感"},"children":[]}]},{"data":{"id":"dhr42fxpuw80","created":1775990438119,"text":"一些相关概念"},"children":[{"data":{"id":"dhr42i1tgxs0","created":1775990442720,"text":"习得性无助"},"children":[{"data":{"id":"dhr42nnr49c0","created":1775990454930,"text":"塞利格曼"},"children":[]},{"data":{"id":"dhr42r7rcmw0","created":1775990462670,"text":"指人或动物反复面对负面事件，感到难以控制，从而学会了放弃和感到无望的现象"},"children":[]}]},{"data":{"id":"dhr42k3vsls0","created":1775990447198,"text":"自我决定"},"children":[{"data":{"id":"dhr434ka7q00","created":1775990491726,"text":"德西"},"children":[]},{"data":{"id":"dhr437c25800","created":1775990497759,"text":"可以使人增加自我控制感，从而减少习得性无助"},"children":[]}]}]},{"data":{"id":"dhr43u5ado00","created":1775990547415,"text":"三个表现"},"children":[{"data":{"id":"dhr43wcs31c0","created":1775990552222,"text":"选择行为"},"children":[{"data":{"id":"dhr48xqdq3s0","created":1775990947042,"text":"个人的自我效能感部分地决定着人们对于活动和特定社会环境的选择。\n在自我效能感的驱动下，我们地行为通常会遵循“中等难度原则”，即倾向于选择适度超出自己能力的事情"},"children":[]}]},{"data":{"id":"dhr43xyogps0","created":1775990555723,"text":"努力付出和坚持不懈"},"children":[{"data":{"id":"dhr44jp01ag0","created":1775990603027,"text":"自我效能感越高，越相信付出会带来更多成功\n因此会付出更多的努力，努力持续的时间也会更长"},"children":[]}]},{"data":{"id":"dhr43yn28nc0","created":1775990557197,"text":"思维方式和情感反应"},"children":[{"data":{"id":"dhr4ar6ivns0","created":1775991089509,"text":"自我效能感者对自身能力有充分的信任，相信努力的作用，因此从一开始就会促使事情向期望的方向发展\n自我效能感低的人则相反。"},"children":[]}]}]},{"data":{"id":"dhr2ynf734o0","created":1775987319846,"text":"四个来源"},"children":[{"data":{"id":"dhr2yp4fl740","created":1775987323549,"text":"获得的成就"},"children":[{"data":{"id":"dhr4bl7wbj40","created":1775991154896,"text":"成功会提高自我效能感评估。"},"children":[]}]},{"data":{"id":"dhr2yrm5e1k0","created":1775987328974,"text":"生理唤起"},"children":[{"data":{"id":"dhr4ev4rvco0","created":1775991411567,"text":"一些生理信息，如紧张、焦虑等很可能会降低个体在特定情境中的自我效能感。\n不过，当人已经在这一情境积累了一定的成功经验时，情绪线索对于自我效能感的影响会降低。"},"children":[]}]},{"data":{"id":"dhr2yyf2exk0","created":1775987343783,"text":"言语说服"},"children":[{"data":{"id":"dhr4fx6nh680","created":1775991494398,"text":"他人的建议、劝告、解释以及自我引导也有助于改变个体的自我效能感。\n然而，依靠这种方法产生的自我效能感并不持久，一旦面临令人困惑或难以处理的情境，就会迅速消失。"},"children":[]}]},{"data":{"id":"dhr2yzqj5340","created":1775987346653,"text":"替代性经验"},"children":[{"data":{"id":"dhr4eprnh7k0","created":1775991399890,"text":"通过观察别人的行为，可以得到替代性经验。\n当人们看到与自己相似情况的人成功时，自我效能感会提高。"},"children":[]}]}]}]},{"data":{"id":"dhr2vvw84m80","created":1775987103198,"text":"自尊"},"children":[{"data":{"id":"dhr2vz51yqw0","created":1775987110262,"text":"定义"},"children":[{"data":{"id":"dhr2zalq4y00","created":1775987370307,"text":"对自己满意的水平，可能积极，可能消极"},"children":[]},{"data":{"id":"dhr33rd7xhs0","created":1775987720255,"text":"注意与“自尊心”即想要维护自身的名誉的心理状态区别开"},"children":[]}]},{"data":{"id":"dhr2zcjur540","created":1775987374548,"text":"理论"},"children":[{"data":{"id":"dhr2zfd6oig0","created":1775987380675,"text":"詹姆斯经典理论"},"children":[{"data":{"id":"dhr2zhrghdk0","created":1775987385891,"text":"自尊=成功/抱负"},"children":[]}]},{"data":{"id":"dhr3rqcri1k0","created":1775989598790,"text":"波普"},"children":[{"data":{"id":"dhr3ty3syiw0","created":1775989772391,"text":"自尊的两个维度"},"children":[{"data":{"id":"dhr3uxcpg800","created":1775989849117,"text":"知觉的自我"},"children":[]},{"data":{"id":"dhr3uz35d7k0","created":1775989852893,"text":"理想的自我"},"children":[]}]},{"data":{"id":"dhr3u0pi2n40","created":1775989778057,"text":"五个体现的方面"},"children":[{"data":{"id":"dhr3vj286i00","created":1775989896372,"text":"社会"},"children":[{"data":{"id":"dhr3w0p5v080","created":1775989934765,"text":"个体对自己和同事互动的满意程度"},"children":[]}]},{"data":{"id":"dhr3vkq1pnk0","created":1775989899990,"text":"学业效能"},"children":[{"data":{"id":"dhr3vrhh4ig0","created":1775989914709,"text":"对于重要事情的控制和支配力"},"children":[]}]},{"data":{"id":"dhr3vmq0zh40","created":1775989904342,"text":"家庭"},"children":[{"data":{"id":"dhr3wawl8vc0","created":1775989956981,"text":"在家庭中是一个有价值的，受其他人关注的成员"},"children":[]}]},{"data":{"id":"dhr3vnfy7mw0","created":1775989905909,"text":"身体意象"},"children":[{"data":{"id":"dhr3wg2c3340","created":1775989968213,"text":"对自己的外表的【观点和看法】"},"children":[]}]},{"data":{"id":"dhr3voyr30w0","created":1775989909223,"text":"整体"},"children":[{"data":{"id":"dhr3wr9bzmw0","created":1775989992581,"text":"指一个人对自我整体上的评价"},"children":[]}]}]}]},{"data":{"id":"dhr3rra80d40","created":1775989600813,"text":"库伯史密斯"},"children":[{"data":{"id":"dhr3y2ejvwo0","created":1775990095205,"text":"建立自尊的四个方面"},"children":[{"data":{"id":"dhr3y49d4a00","created":1775990099245,"text":"能力"},"children":[]},{"data":{"id":"dhr3y5j569s0","created":1775990102013,"text":"个体道德性"},"children":[]},{"data":{"id":"dhr3y6lf3ig0","created":1775990104327,"text":"权力"},"children":[]},{"data":{"id":"dhr3y79n4ps0","created":1775990105792,"text":"个人重要性"},"children":[]}]}]},{"data":{"id":"dhr3rsjnk600","created":1775989603561,"text":"黄希庭"},"children":[{"data":{"id":"dhr3x5o8og00","created":1775990023957,"text":"特殊自尊"},"children":[{"data":{"id":"dhr3xbj0w5k0","created":1775990036702,"text":"对自身个别方面的自尊水平"},"children":[{"data":{"id":"dhr3zwcwmr40","created":1775990238773,"text":"特殊性"},"children":[]},{"data":{"id":"dhr3zxb6l800","created":1775990240846,"text":"情境性"},"children":[]},{"data":{"id":"dhr40090zog0","created":1775990247246,"text":"不稳定性"},"children":[]}]}]},{"data":{"id":"dhr3x6yhzpc0","created":1775990026754,"text":"一般自尊"},"children":[{"data":{"id":"dhr3xge6bi80","created":1775990047293,"text":"从特殊自尊抽象而来的一般的自尊态度"},"children":[]}]},{"data":{"id":"dhr3xaipv0w0","created":1775990034507,"text":"整体自尊"},"children":[{"data":{"id":"dhr3xlh0mc80","created":1775990058349,"text":"这和一般自尊有何区别？？"},"children":[]}]}]}]},{"data":{"id":"dhr3sqafo6g0","created":1775989677014,"text":"一些效应"},"children":[{"data":{"id":"dhr3sse4gps0","created":1775989681590,"text":"焦点效应"},"children":[{"data":{"id":"dhr3t6i0k7c0","created":1775989712301,"text":"高估其他人注意自己的概率"},"children":[]}]},{"data":{"id":"dhr3svjdfp40","created":1775989688438,"text":"透明度【错觉】"},"children":[{"data":{"id":"dhr3t9kddqw0","created":1775989718973,"text":"高估自己表达隐藏情绪被他人注意到的概率"},"children":[]}]},{"data":{"id":"dhr3szbitg00","created":1775989696671,"text":"虚假一致性效应"},"children":[{"data":{"id":"dhr3t2fousg0","created":1775989703453,"text":"高估他人赞同自己观点的概率"},"children":[]},{"data":{"id":"dhr40cgnvw80","created":1775990273829,"text":"用以支持自身立场；当自己取得成功时更容易发生"},"children":[]},{"data":{"id":"dhr40r5ddww0","created":1775990305798,"text":"与之相应的，我们可能会认为自己与众不同（？这不是另一个效应吗）"},"children":[]}]}]},{"data":{"id":"dhr3rtxqx1k0","created":1775989606590,"text":"影响因素"},"children":[{"data":{"id":"dhr3rwiqlfs0","created":1775989612212,"text":"环境与经验"},"children":[]},{"data":{"id":"dhr3scq7ibc0","created":1775989647493,"text":"家庭"},"children":[]},{"data":{"id":"dhr3sdqbx880","created":1775989649677,"text":"学校"},"children":[]},{"data":{"id":"dhr3seeyu1s0","created":1775989651166,"text":"其他个人因素"},"children":[]}]}]},{"data":{"id":"dhr2vwqscgg0","created":1775987105046,"text":"文化与自我"},"children":[{"data":{"id":"dhr2xlu7m5c0","created":1775987238037,"text":"“独立自我-互依自我”二分法"},"children":[{"data":{"id":"dhr2ztoiltk0","created":1775987411835,"text":"马科思和北山"},"children":[]},{"data":{"id":"dhr2zydo3wg0","created":1775987422063,"text":"美国文化与日本文化对比"},"children":[]},{"data":{"id":"dhr52lj96zk0","created":1775993271415,"text":"两类自我"},"children":[{"data":{"id":"dhr52pj1v4g0","created":1775993280110,"text":"独立自我"},"children":[{"data":{"id":"dhr5aixs23c0","created":1775993892676,"text":"西方文虎，个人价值，自我是独立实体；\n自我概念和社会背景是分离的"},"children":[]}]},{"data":{"id":"dhr52uvehkg0","created":1775993291740,"text":"互依自我"},"children":[{"data":{"id":"dhr5as9ufb40","created":1775993912996,"text":"自我和环境互相依存"},"children":[]}]}]},{"data":{"id":"dhr30ab8u0o0","created":1775987448038,"text":"评价"},"children":[{"data":{"id":"dhr32xwmw1c0","created":1775987656125,"text":"群际理论中得到最广泛的认可"},"children":[]}]}]},{"data":{"id":"dhr4htdy30g0","created":1775991642861,"text":"霍夫斯泰德的工作价值观研究"},"children":[{"data":{"id":"dhr4i1bpq8g0","created":1775991660140,"text":"美国人的个体主义倾向更明显"},"children":[]},{"data":{"id":"dhr4i46n6fs0","created":1775991666364,"text":"亚洲人的集体主义倾向更明显"},"children":[]}]},{"data":{"id":"dhr2xrxck7c0","created":1775987251287,"text":"文化自我的动态建构理论"},"children":[{"data":{"id":"dhr332k0ozs0","created":1775987666246,"text":"两个方面"},"children":[{"data":{"id":"dhr335ctzn40","created":1775987672342,"text":"文化本身作为松散结构"},"children":[]},{"data":{"id":"dhr337e4ig00","created":1775987676774,"text":"个体可以转换采用的文化范式"},"children":[]}]}]},{"data":{"id":"dhr2xyw6g940","created":1775987266454,"text":"认知心理学的两个效应"},"children":[{"data":{"id":"dhr2y4fonyw0","created":1775987278517,"text":"自我参照效应"},"children":[{"data":{"id":"dhr31bj8eiw0","created":1775987529062,"text":"回忆相关于自己的描述更加容易"},"children":[]},{"data":{"id":"dhr31k10hpc0","created":1775987547551,"text":"实验方法"},"children":[{"data":{"id":"dhr31qvvgfk0","created":1775987562478,"text":"？？"},"children":[]}]}]},{"data":{"id":"dhr2y5xy25c0","created":1775987281798,"text":"文化启动效应？"},"children":[{"data":{"id":"dhr31x95wy00","created":1775987576342,"text":"接受了独立自我文化范式的启动后，回忆关于自我的信息变得更加容易"},"children":[]},{"data":{"id":"dhr32dx1msg0","created":1775987612614,"text":"实验方法"},"children":[{"data":{"id":"dhr32fv8kq00","created":1775987616859,"text":"？"},"children":[]}]}]}]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}