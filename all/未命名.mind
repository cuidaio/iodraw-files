{"root":{"data":{"id":"dhqc23e3aag0","created":1775911419733,"text":"刻板印象与归因"},"children":[{"data":{"id":"dhqc2h9h2tc0","created":1775911449929,"text":"刻板印象"},"children":[{"data":{"id":"dhqc2jzp7ds0","created":1775911455868,"text":"定义"},"children":[{"data":{"id":"dhqcqfsvi800","created":1775913327488,"text":"也称【类属性思维】，\n是指人们通过整合有关信息及个人经验形成的一种【针对特定对象】的【既定】认知模式"},"children":[]}]},{"data":{"id":"dhqc2lhgxao0","created":1775911459119,"text":"性质"},"children":[{"data":{"id":"dhqc5z142000","created":1775911723698,"text":"僵化性，【广泛性，无意识性】"},"children":[]}]},{"data":{"id":"dhqc2mar9s00","created":1775911460890,"text":"分类"},"children":[{"data":{"id":"dhqc5rwy4o00","created":1775911708208,"text":"性别/地域/种族"},"children":[]}]},{"data":{"id":"dhqc7jua7e00","created":1775911847361,"text":"成因理论"},"children":[{"data":{"id":"dhqc7n89ktc0","created":1775911854737,"text":"社会认同"},"children":[{"data":{"id":"dhqc7sy2f9s0","created":1775911867181,"text":"偏内贬外"},"children":[]}]},{"data":{"id":"dhqc7p52yy80","created":1775911858898,"text":"弱势群体的社会认同"},"children":[{"data":{"id":"dhqc80rkk6o0","created":1775911884203,"text":"偏外贬内"},"children":[]}]}]},{"data":{"id":"dhqc2ppntag0","created":1775911468322,"text":"功能"},"children":[{"data":{"id":"dhqcr8jiw480","created":1775913390050,"text":"定义中：简化认知过程，减轻认知负担，节约认知资源，提高认知效率→帮助适应复杂环境"},"children":[]},{"data":{"id":"dhqc8a61qxs0","created":1775911904669,"text":"正面：简化认知过程，迅速获得对于特定对象的概念，形成印象，有助于适应社会"},"children":[]},{"data":{"id":"dhqc8g4bt4g0","created":1775911917626,"text":"负面"},"children":[{"data":{"id":"dhqcsf8o3080","created":1775913482995,"text":"总论"},"children":[{"data":{"id":"dhqcsyz1neg0","created":1775913525949,"text":"经常是对信息的扭曲"},"children":[]},{"data":{"id":"dhqct3akj0g0","created":1775913535353,"text":"过度夸大或缩小群体特征，忽视成员的【异质性】，\n产生先入为主、以偏概全的偏差"},"children":[]},{"data":{"id":"dhqctl1cnlc0","created":1775913573977,"text":"夸大群体间的【差异性】，从而形成偏见和歧视"},"children":[]}]},{"data":{"id":"dhqc8qgelzs0","created":1775911940124,"text":"刻板印象之于观察者"},"children":[{"data":{"id":"dhqc8xstobc0","created":1775911956112,"text":"同化效应（印象→行为）"},"children":[{"data":{"id":"dhqcuw0fk9s0","created":1775913676230,"text":"刻板印象的激活会使人们做出与刻板印象一致的行为"},"children":[]}]},{"data":{"id":"dhqc92776ts0","created":1775911965689,"text":"念动论（观念→行为）"},"children":[{"data":{"id":"dhqcwvmp5nk0","created":1775913832128,"text":"如果刻板印象中包含了行为信息，当刻板印象被激活时，这些行为很可能会自动启动。"},"children":[]}]},{"data":{"id":"dhqc93vfew80","created":1775911969330,"text":"僵化性/对抗相反信息（证实偏差）"},"children":[{"data":{"id":"dhqcxr4t4aw0","created":1775913900704,"text":"为了保持刻板印象的一致性，个体会出现【选择性注意】\n关注证实他们期望的信息，而忽略与期望不一致的信息\n研究发现，即使出现与刻板印象相反的证据，人们也更倾向于维护而不是改变……"},"children":[]}]}]},{"data":{"id":"dhqc8u95ipk0","created":1775911948393,"text":"刻板印象之于被观察者"},"children":[{"data":{"id":"dhqc94r1j140","created":1775911971242,"text":"刻板印象威胁（恐惧→↓行动）"},"children":[{"data":{"id":"dhqd2gdltfk0","created":1775914269112,"text":"斯提尔"},"children":[]},{"data":{"id":"dhqd2izqjug0","created":1775914274805,"text":"消极的自我刻板印象被激活时，任务完成水平降低"},"children":[]},{"data":{"id":"dhqd3smonk80","created":1775914374146,"text":"个体会因为害怕印证这一刻板印象，产生压力感，从而……"},"children":[]}]}]}]}]},{"data":{"id":"dhqc2rhfc9s0","created":1775911472177,"text":"改善"},"children":[{"data":{"id":"dhqc97p9fog0","created":1775911977665,"text":"直接接触【不符合原有刻板印象的】成员"},"children":[]},{"data":{"id":"dhqc9g3cgew0","created":1775911995931,"text":"间接呈现【反刻板印象的描述】信息"},"children":[]},{"data":{"id":"dhqc9ka19pk0","created":1775912005042,"text":"发挥媒体信息对受众的影响作用"},"children":[]}]},{"data":{"id":"dhqc2xgk6880","created":1775911485186,"text":"测量"},"children":[{"data":{"id":"dhqc9btb8eo0","created":1775911986617,"text":"刻板解释偏差（SEB）"},"children":[{"data":{"id":"dhqd0d830g00","created":1775914105519,"text":"定位"},"children":[{"data":{"id":"dhqd04mw3q80","created":1775914086824,"text":"内隐刻板印象的新型测量方法"},"children":[]}]},{"data":{"id":"dhqd0g8h4rk0","created":1775914112073,"text":"理论依据"},"children":[{"data":{"id":"dhqd0jjxisg0","created":1775914119296,"text":"哈斯蒂"},"children":[]},{"data":{"id":"dhqd0npksqw0","created":1775914128345,"text":"人们在面对与期望值不一致的行为时，会进行更多的解释行为（即归因行为），从而合理化不一致"},"children":[]}]},{"data":{"id":"dhqd1n8w23s0","created":1775914205700,"text":"功能"},"children":[{"data":{"id":"dhqd1po0rsg0","created":1775914210968,"text":"反映了个人对特定社会群体的刻板印象在信息加工过程中无意识地发生作用"},"children":[]},{"data":{"id":"dhqd29krfwg0","created":1775914254307,"text":"作为测量内隐态度的一种指标"},"children":[]}]}]}]}]},{"data":{"id":"dhqc411muvc0","created":1775911571355,"text":"偏见与歧视"},"children":[{"data":{"id":"dhqc448q4yo0","created":1775911578314,"text":"定义"},"children":[{"data":{"id":"dhqd4lub7iw0","created":1775914437734,"text":"偏见（情感）"},"children":[{"data":{"id":"dhqd4wahczc0","created":1775914460480,"text":"分支主题"},"children":[]}]},{"data":{"id":"dhqd4oqi1sw0","created":1775914444034,"text":"歧视（行动）"},"children":[]}]},{"data":{"id":"dhqc451fhi80","created":1775911580049,"text":"分类"},"children":[{"data":{"id":"dhqclkjodc00","created":1775912945995,"text":"性别/种族"},"children":[]}]},{"data":{"id":"dhqc46b7a8w0","created":1775911582817,"text":"成因"},"children":[{"data":{"id":"dhqclnd29s80","created":1775912952126,"text":"社会化"},"children":[]},{"data":{"id":"dhqdw99z3cg0","created":1775916604580,"text":"认知因素"},"children":[]},{"data":{"id":"dhqclpvhb540","created":1775912957593,"text":"动机因素"},"children":[]},{"data":{"id":"dhqcltwhxvk0","created":1775912966361,"text":""},"children":[]}]},{"data":{"id":"dhqc472ukkw0","created":1775911584489,"text":"改善"},"children":[{"data":{"id":"dhqclzna4ig0","created":1775912978865,"text":"直接接触"},"children":[]},{"data":{"id":"dhqcm2tgl7k0","created":1775912985769,"text":"社会层面"},"children":[]}]}]},{"data":{"id":"dhqc4cg21mw0","created":1775911596171,"text":"归因","expandState":"expand"},"children":[{"data":{"id":"dhqc4dzkwqg0","created":1775911599529,"text":"定义"},"children":[{"data":{"id":"dhqdvdr7uog0","created":1775916535965,"text":"指根据有关的外部信息、线索判断人的内在状态，\n或者依据外在行为表现推测行为原因的【过程】"},"children":[]}]},{"data":{"id":"dhqc4hycjwg0","created":1775911608161,"text":"功能"},"children":[{"data":{"id":"dhqdk61t2yw0","created":1775915657186,"text":"不仅是一种心理过程，而且是一种需要"},"children":[]},{"data":{"id":"dhqdk9ho23k0","created":1775915664675,"text":"使对事物有预见性，是人们形成一系列【从经验中总结出的/有关于人的行为及其原因的】理论"},"children":[]},{"data":{"id":"dhqdl6hn08o0","created":1775915736507,"text":"使我们【对周围世界和自己】有一个【相对固定、前后一致】的看法，使得我们能够适应世界"},"children":[]}]},{"data":{"id":"dhqc2myt8i80","created":1775911462345,"text":"理论"},"children":[{"data":{"id":"dhqc63qvbhc0","created":1775911733962,"text":"海德的朴素心理学和现象学"},"children":[{"data":{"id":"dhqcbf37s3c0","created":1775912150474,"text":"内-外"},"children":[]},{"data":{"id":"dhqcbhz47dc0","created":1775912156757,"text":"类型"},"children":[{"data":{"id":"dhqcbmc497c0","created":1775912166250,"text":"本性归因"},"children":[{"data":{"id":"dhqcq1np7ww0","created":1775913296700,"text":"内"},"children":[]}]},{"data":{"id":"dhqcbp180bc0","created":1775912172122,"text":"情境归因"},"children":[{"data":{"id":"dhqcq36gylc0","created":1775913300012,"text":"外"},"children":[]}]},{"data":{"id":"dhqcbtw9fdk0","created":1775912182706,"text":"综合归因"},"children":[{"data":{"id":"dhqcq46dsao0","created":1775913302184,"text":"内+外"},"children":[]}]}]},{"data":{"id":"dhqcc1gg0jk0","created":1775912199163,"text":"评价"},"children":[{"data":{"id":"dhqcc3r4j800","created":1775912204163,"text":"+：探索\n-：简单"},"children":[]}]}]},{"data":{"id":"dhqc68bbpmw0","created":1775911743906,"text":"相应推断理论"},"children":[{"data":{"id":"dhqccg8imig0","created":1775912231336,"text":"【琼斯】和【戴维斯】"},"children":[]},{"data":{"id":"dhqccmmw83c0","created":1775912245266,"text":"从外显行为推内部因素"},"children":[]},{"data":{"id":"dhqccrysia80","created":1775912256869,"text":"影响推理可靠性的因素"},"children":[{"data":{"id":"dhqccve10dc0","created":1775912264321,"text":"行为结果的严重性"},"children":[]},{"data":{"id":"dhqcd1s4w4g0","created":1775912278234,"text":"选择自由性（行动是自由意志的体现）"},"children":[]},{"data":{"id":"dhqcd83ae3k0","created":1775912291970,"text":"社会赞许性（社会对行为的赞许）"},"children":[]},{"data":{"id":"dhqchlwc93k0","created":1775912635481,"text":"非共同性效应（？）"},"children":[{"data":{"id":"dhqdmk2cwtk0","created":1775915844422,"text":"【独特性】"},"children":[]},{"data":{"id":"dhqdmla2w800","created":1775915847066,"text":"非共同性因素越少，推断的可靠性越高"},"children":[]}]}]}]},{"data":{"id":"dhqc6dvwl7k0","created":1775911756035,"text":"韦纳的动机归因理论"},"children":[{"data":{"id":"dhqchuchjog0","created":1775912653872,"text":"三个维度"},"children":[{"data":{"id":"dhqchzf7exs0","created":1775912664920,"text":"内外源（内在-外在）"},"children":[]},{"data":{"id":"dhqci7edvv40","created":1775912682285,"text":"稳定性（稳定-不稳定）"},"children":[]},{"data":{"id":"dhqci31a1kw0","created":1775912672785,"text":"可控性（可控-不可控）"},"children":[]}]},{"data":{"id":"dhqcif7hleo0","created":1775912699282,"text":"四个因素"},"children":[{"data":{"id":"dhqcigkflb40","created":1775912702241,"text":"能力"},"children":[]},{"data":{"id":"dhqcii4jsso0","created":1775912705634,"text":"努力"},"children":[]},{"data":{"id":"dhqciiw675s0","created":1775912707305,"text":"任务难度"},"children":[]},{"data":{"id":"dhqcijrxgm00","created":1775912709225,"text":"运气"},"children":[]}]},{"data":{"id":"dhqdmxptz1c0","created":1775915874140,"text":"结论","expandState":"expand"},"children":[{"data":{"id":"dhqdmyzh4w00","created":1775915876900,"text":"无论成败，归因于努力，情绪反应 ＞ that is 能力"},"children":[]},{"data":{"id":"dhqdrr64ork0","created":1775916251708,"text":"低能力高努力高评价，高能力低努力低评价"},"children":[]}]},{"data":{"id":"dhqciu9o7eg0","created":1775912732066,"text":"评价"},"children":[{"data":{"id":"dhqciz187680","created":1775912742439,"text":"+（教心）：\n从学生的角度分析学习成败的原因，学生的归因又能预测学习动机，对教育实践有重要意义\n成败归因分三维，高度概括性；\n又有科学性，又有实践价值，为教育实践提供了"},"children":[]},{"data":{"id":"dhqcj3fju0g0","created":1775912752012,"text":"-：\n三维六因素能够完全揭示人类的归因吗？\n努力可控吗？"},"children":[]}]}]},{"data":{"id":"dhqc6nwtqkg0","created":1775911777858,"text":"凯利的三维协变模型"},"children":[{"data":{"id":"dhqdqwzdc680","created":1775916185996,"text":"科学家的归因法\n寻求一种效应是否发生的规律性协变"},"children":[]},{"data":{"id":"dhqcjhrvlww0","created":1775912783232,"text":"三个考虑维度"},"children":[{"data":{"id":"dhqcjksdd7k0","created":1775912789793,"text":"一致性"},"children":[]},{"data":{"id":"dhqcjni0uz40","created":1775912795697,"text":"一贯性"},"children":[]},{"data":{"id":"dhqcjofmzzs0","created":1775912797730,"text":"差别性"},"children":[]}]},{"data":{"id":"dhqcjwec3a80","created":1775912815065,"text":"三个信息资料"},"children":[{"data":{"id":"dhqck0g4xds0","created":1775912823881,"text":"刺激物"},"children":[]},{"data":{"id":"dhqck2y5hz40","created":1775912829324,"text":"行动主体"},"children":[]},{"data":{"id":"dhqck5rc2ls0","created":1775912835442,"text":"情境"},"children":[]}]},{"data":{"id":"dhqckavw15c0","created":1775912846602,"text":"评价"},"children":[{"data":{"id":"dhqckev231k0","created":1775912855258,"text":"+：严密的逻辑分析模式，科学（方差分析模型）、细致、合理"},"children":[]},{"data":{"id":"dhqckm165400","created":1775912870866,"text":"-：过分强调逻辑性，是理想化模式，脱离一般人活动实际"},"children":[]}]}]},{"data":{"id":"dhqc6s5sflk0","created":1775911787107,"text":"异常条件【聚焦】模型"},"children":[{"data":{"id":"dhqdti8gzfk0","created":1775916388987,"text":"希尔顿和斯拉格斯基"},"children":[]},{"data":{"id":"dhqckpo8bko0","created":1775912878790,"text":"两个步骤"},"children":[{"data":{"id":"dhqcktdmwog0","created":1775912886857,"text":"逆向标准→必要条件"},"children":[]},{"data":{"id":"dhqckw5xgrk0","created":1775912892921,"text":"对照标准→属于异常的条件（充分条件）"},"children":[]}]},{"data":{"id":"dhqdu9znofc0","created":1775916449404,"text":"需要对照的两种事件状态"},"children":[{"data":{"id":"dhqdudx9p5s0","created":1775916457967,"text":"目标事件"},"children":[]},{"data":{"id":"dhqdugbvqxc0","created":1775916463204,"text":"没有发生目标事件的背景事件"},"children":[]}]},{"data":{"id":"dhqcl85e4zs0","created":1775912919010,"text":"评价"},"children":[{"data":{"id":"dhqclay4fq00","created":1775912925101,"text":"+：\n不需要进行复杂的条件匹配，\n不将归因者局限在三个维度中\n合乎实际"},"children":[]}]}]}]},{"data":{"id":"dhqcmnmv92o0","created":1775913031083,"text":"三原则"},"children":[{"data":{"id":"dhqcmr2jp200","created":1775913038561,"text":"海德的原则"},"children":[{"data":{"id":"dhqcn404fgg0","created":1775913066713,"text":"共变性"},"children":[{"data":{"id":"dhqcnrzen0w0","created":1775913118912,"text":"X变化，Y同时变化→X是Y的原因"},"children":[]}]}]},{"data":{"id":"dhqcmtfr4hk0","created":1775913043713,"text":"凯利的原则"},"children":[{"data":{"id":"dhqcmx1j8e80","created":1775913051561,"text":"打折扣"},"children":[{"data":{"id":"dhqcnxo7l6w0","created":1775913131296,"text":"X,Y,Z↑→R；[X↑→R]↓"},"children":[]}]},{"data":{"id":"dhqcmz8ad800","created":1775913056322,"text":"放大/协变"},"children":[{"data":{"id":"dhqco9ryaa80","created":1775913157643,"text":"[X↑→R，Y,Z↓→R]→[X↑→R]↑"},"children":[]}]}]}]},{"data":{"id":"dhqc5lkbxgg0","created":1775911694385,"text":"归因偏差"},"children":[{"data":{"id":"dhqc9sc8fj40","created":1775912022589,"text":"基本归因偏差"},"children":[{"data":{"id":"dhqcadleqi80","created":1775912068857,"text":"看别人时，成功归外，失败归内"},"children":[]}]},{"data":{"id":"dhqc9vu4gw00","created":1775912030202,"text":"观察者-活动者效应"},"children":[{"data":{"id":"dhqcalfm73k0","created":1775912085921,"text":"活动者看自己的成功归内，失败归外；观察者看活动者正相反"},"children":[]}]},{"data":{"id":"dhqc9zx8cco0","created":1775912039097,"text":"自利归因偏差"},"children":[{"data":{"id":"dhqcb237vs80","created":1775912122176,"text":"自己的成功归内，失败归外；别人的成功归外，失败归内"},"children":[]}]}]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}